// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  REALLOCATED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditItemResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

// ─── Auth Infrastructure (not in PRD business schema, required for auth) ─────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PRD Models ──────────────────────────────────────────────────────────────

/// users — PRD 3 §3
model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(EMPLOYEE)
  departmentId String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  department              Department?          @relation("DeptMembers", fields: [departmentId], references: [id])
  // Department this user is head of
  departmentsHeaded       Department[]         @relation("DeptHead")
  refreshTokens           RefreshToken[]
  resetTokens             PasswordResetToken[]
  // Assets held directly by this user
  assetsHeld              Asset[]              @relation("AssetHolderUser")
  // Allocations
  allocationsAsHolder     Allocation[]         @relation("AllocationHolder")
  // Transfer requests
  transfersRequested      TransferRequest[]    @relation("TransferRequestedBy")
  transfersApproved       TransferRequest[]    @relation("TransferApprovedBy")
  transfersFromUser       TransferRequest[]    @relation("TransferFromUser")
  transfersToUser         TransferRequest[]    @relation("TransferToUser")
  // Bookings
  bookings                Booking[]
  // Maintenance
  maintenanceRaised       MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceTechnician   MaintenanceRequest[] @relation("MaintenanceTechnician")
  maintenanceApproved     MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  // Audit
  auditCycleAuditors      AuditCycleAuditor[]
  // Notifications & logs
  notifications           Notification[]
  activityLogs            ActivityLog[]
}

/// departments — PRD 3 §3
model Department {
  id                 String           @id @default(cuid())
  name               String           @unique
  headId             String?
  parentDepartmentId String?
  status             DepartmentStatus @default(ACTIVE)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  head             User?        @relation("DeptHead", fields: [headId], references: [id])
  parentDepartment Department?  @relation("DeptHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments Department[] @relation("DeptHierarchy")
  users            User[]       @relation("DeptMembers")
  // Assets held by this department
  assetsHeld       Asset[]      @relation("AssetHolderDept")
  allocations      Allocation[] @relation("AllocationHolderDept")
  // Transfer requests involving this department
  transfersFrom    TransferRequest[] @relation("TransferFromDept")
  transfersTo      TransferRequest[] @relation("TransferToDept")
  // Audit cycles scoped to this department
  auditCycles      AuditCycle[]
}

/// asset_categories — PRD 3 §3
model AssetCategory {
  id   String @id @default(cuid())
  name String @unique

  assets         Asset[]
  customFields   CategoryCustomField[]
}

/// category_custom_fields — PRD 3 §3
/// (separate table per PRD; Json blob acceptable shortcut but we implement the table)
model CategoryCustomField {
  id         String @id @default(cuid())
  categoryId String
  fieldKey   String
  fieldType  String // "number" | "date" | "text"

  category AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

/// assets — PRD 3 §3
/// CHECK constraint (not both holder_user_id and holder_department_id set)
/// enforced via @@check below (Prisma doesn't natively emit raw CHECK, done via migration SQL)
model Asset {
  id                  String      @id @default(cuid())
  name                String
  serialNumber        String?
  assetTag            String      @unique
  categoryId          String
  status              AssetStatus @default(AVAILABLE)
  holderUserId        String?
  holderDepartmentId  String?
  acquisitionDate     DateTime?
  acquisitionCost     Decimal?
  condition           String?
  location            String?
  isBookable          Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  category           AssetCategory        @relation(fields: [categoryId], references: [id])
  holderUser         User?                @relation("AssetHolderUser", fields: [holderUserId], references: [id])
  holderDepartment   Department?          @relation("AssetHolderDept", fields: [holderDepartmentId], references: [id])
  allocations        Allocation[]
  transferRequests   TransferRequest[]
  bookings           Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems         AuditItem[]

  // Indexes — PRD 3 §4
  @@index([assetTag])
  @@index([serialNumber])
  @@index([status])
  @@index([categoryId])
  @@index([location])
}

/// allocations — PRD 3 §3
model Allocation {
  id                    String           @id @default(cuid())
  assetId               String
  holderUserId          String?
  holderDepartmentId    String?
  allocatedDate         DateTime?
  expectedReturnDate    DateTime?
  returnedDate          DateTime?
  conditionCheckinNotes String?
  status                AllocationStatus @default(ACTIVE)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  asset            Asset       @relation(fields: [assetId], references: [id])
  holderUser       User?       @relation("AllocationHolder", fields: [holderUserId], references: [id])
  holderDepartment Department? @relation("AllocationHolderDept", fields: [holderDepartmentId], references: [id])

  // Index — PRD 3 §4
  @@index([expectedReturnDate])
}

/// transfer_requests — PRD 3 §3
model TransferRequest {
  id                     String         @id @default(cuid())
  assetId                String
  fromHolderUserId       String?
  fromHolderDepartmentId String?
  toHolderUserId         String?
  toHolderDepartmentId   String?
  status                 TransferStatus @default(REQUESTED)
  requestedById          String
  approvedById           String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  asset              Asset       @relation(fields: [assetId], references: [id])
  fromHolderUser     User?       @relation("TransferFromUser", fields: [fromHolderUserId], references: [id])
  fromHolderDept     Department? @relation("TransferFromDept", fields: [fromHolderDepartmentId], references: [id])
  toHolderUser       User?       @relation("TransferToUser", fields: [toHolderUserId], references: [id])
  toHolderDept       Department? @relation("TransferToDept", fields: [toHolderDepartmentId], references: [id])
  requestedBy        User        @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy         User?       @relation("TransferApprovedBy", fields: [approvedById], references: [id])
}

/// bookings — PRD 3 §3
/// resource_id points to assets where is_bookable = true
/// Overlap exclusion constraint applied via raw SQL migration (btree_gist)
model Booking {
  id          String        @id @default(cuid())
  resourceId  String
  bookedById  String
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(UPCOMING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  resource  Asset @relation(fields: [resourceId], references: [id])
  bookedBy  User  @relation(fields: [bookedById], references: [id])

  // GiST index from exclusion constraint covers overlap — PRD 3 §4
  @@index([resourceId])
}

/// maintenance_requests — PRD 3 §3
model MaintenanceRequest {
  id               String            @id @default(cuid())
  assetId          String
  raisedById       String
  issueDescription String
  priority         String            // LOW | MEDIUM | HIGH | CRITICAL
  photoUrl         String?
  status           MaintenanceStatus @default(PENDING)
  technicianId     String?
  approvedById     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  asset      Asset @relation(fields: [assetId], references: [id])
  raisedBy   User  @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  technician User? @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  approvedBy User? @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
}

/// audit_cycles — PRD 3 §3
model AuditCycle {
  id             String           @id @default(cuid())
  name           String           @default("Audit Cycle")
  departmentId   String?
  location       String?
  dateRangeStart DateTime
  dateRangeEnd   DateTime
  status         AuditCycleStatus @default(OPEN)
  closedAt       DateTime?
  discrepancyReport Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  department Department?         @relation(fields: [departmentId], references: [id])
  auditors   AuditCycleAuditor[]
  items      AuditItem[]
}

/// audit_cycle_auditors (junction, many-to-many) — PRD 3 §3
model AuditCycleAuditor {
  auditCycleId String
  userId       String

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@id([auditCycleId, userId])
}

/// audit_items — PRD 3 §3
model AuditItem {
  id           String          @id @default(cuid())
  auditCycleId String
  assetId      String
  result       AuditItemResult
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id])

  @@unique([auditCycleId, assetId])
}

/// notifications — PRD 3 §3
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite index — PRD 3 §4
  @@index([userId, read])
}

/// activity_logs — PRD 3 §3
model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  timestamp  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])
}
